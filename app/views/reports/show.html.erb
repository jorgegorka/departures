<% content_for :title, "Reports" %>

<div data-workspace-slug="<%= Current.workspace&.slug %>" data-project-slug="<%= Current.project&.slug %>">
<% if Current.project %>
  <div class="page-head">
    <h1 class="page-head__title"><%= Current.project.name %> reports</h1>
    <%= form_with url: report_path, method: :get, data: { controller: "auto-submit" } do |form| %>
      <%= form.select :range,
            metric_range_options(@report.range),
            {}, class: "input input--select", aria: { label: "Time range" },
            data: { action: "change->auto-submit#submit" } %>
    <% end %>
  </div>

  <% cache @report.cache_key, expires_in: 60.seconds do %>
    <% display_labels = chart_display_labels(@report.labels, @report.range) %>

    <section class="report-section">
      <h2 class="report-section__title">Sending &amp; engagement, <%= metric_range_caption(@report.range) %></h2>
      <% if @report.accepted_count.zero? %>
        <p class="board-hint">No sends in this period.</p>
      <% end %>
      <div class="chart-grid">
        <% { "Sent" => [ :sent, "neutral", @report.accepted_count ],
             "Delivered" => [ :delivered, "primary", nil ],
             "Opened" => [ :opened, "neutral", nil ],
             "Clicked" => [ :clicked, "neutral", nil ],
             "Bounced" => [ :bounced, "attention", nil ],
             "Complained" => [ :complained, "attention", nil ] }.each do |label, (key, role, total)| %>
          <%= render "shared/series_chart", small: true, title: label,
                total: number_with_delimiter(total || @report.series.fetch(key).sum),
                labels: display_labels,
                datasets: [ { label: label, data: @report.series.fetch(key), role: role } ] %>
        <% end %>
      </div>
    </section>

    <section class="report-section">
      <h2 class="report-section__title">Deliverability</h2>
      <div class="report-stats">
        <div class="report-stats__item">
          <p class="chart-grid__title">Hard bounces</p>
          <p class="chart-grid__total"><%= number_with_delimiter(@report.hard_bounce_count) %></p>
        </div>
        <div class="report-stats__item">
          <p class="chart-grid__title">Soft bounces</p>
          <p class="chart-grid__total"><%= number_with_delimiter(@report.soft_bounce_count) %></p>
        </div>
        <div class="report-stats__item">
          <p class="chart-grid__title">Bounce rate</p>
          <p class="chart-grid__total"><%= @report.bounce_rate %>%</p>
        </div>
        <div class="report-stats__item">
          <p class="chart-grid__title">Active suppressions</p>
          <p class="chart-grid__total"><%= number_with_delimiter(@report.active_suppression_count) %></p>
        </div>
      </div>
      <%= render "shared/series_chart", small: true,
            caption: "New suppressions, #{metric_range_caption(@report.range)}",
            labels: display_labels,
            datasets: [ { label: "New suppressions", data: @report.suppression_series, role: "attention" } ] %>
    </section>

    <section class="report-section">
      <h2 class="report-section__title">SES quota</h2>
      <% if @report.sources.any? %>
        <% @report.sources.each do |source| %>
          <%= render "quota_meter", source: source %>
        <% end %>
      <% else %>
        <p class="board-hint">No sources connected yet.</p>
      <% end %>
    </section>

    <%= render "breakdown_table", title: "By source", key_header: "Source", rows: @report.breakdown_by_source %>
    <%= render "breakdown_table", title: "By sending domain", key_header: "Domain", rows: @report.breakdown_by_domain %>
    <%= render "breakdown_table", title: "By tag", key_header: "Tag", rows: @report.breakdown_by_tag %>
  <% end %>
<% else %>
  <div class="empty-state">
    <h1 class="empty-state__title">No project yet</h1>
    <p class="empty-state__lead">Create a project to start sending — reports will fill in as mail flows.</p>
    <%= link_to "Get started", onboarding_path, class: "btn btn--primary btn--medium" %>
  </div>
<% end %>
</div>
