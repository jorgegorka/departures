<!DOCTYPE html>
<html>
  <%= render "layouts/head" %>

  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <% if authenticated? %>
      <header class="shell-header">
        <div class="shell-header__identity center main-width">
          <%= link_to root_path, class: "wordmark" do %>Departures<span class="wordmark__dot" aria-hidden="true">.</span><% end %>
          <div class="shell-header__actions">
            <%= link_to "Send test", new_test_email_path, class: "btn btn--secondary" %>
            <%= link_to "Docs", docs_path, class: "btn btn--plain" %>
            <%= render "workspaces/switcher" %>
            <div class="nav__group" data-controller="menu"
                data-action="keydown.esc->menu#closeAndFocus keydown.down->menu#moveDown keydown.up->menu#moveUp focusout->menu#closeOnFocusOut">
              <%= button_tag type: "button", class: "btn btn--plain",
                    data: { menu_target: "button", action: "menu#toggle" },
                    aria: { expanded: "false" } do %>
                Account<%= icon_tag "caret-down", class: "nav__caret" %>
              <% end %>
              <div class="menu menu--end" data-menu-target="panel" hidden>
                <p class="menu__heading"><%= Current.user.email_address %></p>
                <%= menu_link_to "Security", user_sessions_path %>
                <hr class="menu__rule">
                <%= button_to "Sign out", session_path, method: :delete, class: "menu__item" %>
              </div>
            </div>
          </div>
        </div>
        <div class="shell-header__nav center main-width">
          <%= render "layouts/nav" %>
        </div>
      </header>
    <% end %>
    <main id="main" class="center pad main-width">
      <% if notice.present? %>
        <div class="flash flash--notice" role="status" data-controller="flash">
          <%= icon_tag "check-circle" %>
          <p class="flash__message"><%= notice %></p>
          <button type="button" class="flash__dismiss" data-action="flash#dismiss" aria-label="Dismiss">
            <%= icon_tag "close" %>
          </button>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash--alert" role="alert" data-controller="flash">
          <%= icon_tag "alert-circle" %>
          <p class="flash__message"><%= alert %></p>
          <button type="button" class="flash__dismiss" data-action="flash#dismiss" aria-label="Dismiss">
            <%= icon_tag "close" %>
          </button>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
