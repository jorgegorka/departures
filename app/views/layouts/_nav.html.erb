<nav class="nav" aria-label="Primary">
  <%= link_to "Overview", root_path, class: "nav__link",
        aria: { current: (nav_current?(root_path, exact: true) || nav_current?(report_path)) ? "page" : nil } %>
  <%= nav_link_to "Activity", activity_path %>
  <%= nav_link_to "Emails", emails_path %>

  <div class="nav__group" data-controller="menu"
      data-action="keydown.esc->menu#closeAndFocus keydown.down->menu#moveDown keydown.up->menu#moveUp focusout->menu#closeOnFocusOut">
    <%= button_tag type: "button", class: "nav__link nav__trigger",
          data: { menu_target: "button", action: "menu#toggle" },
          aria: { expanded: "false", current: nav_section_current?(bounces_path, suppressions_path) ? "true" : nil } do %>
      Deliverability<%= icon_tag "caret-down", class: "nav__caret" %>
    <% end %>
    <div class="menu" data-menu-target="panel" hidden>
      <%= menu_link_to "Bounces", bounces_path %>
      <%= menu_link_to "Suppressions", suppressions_path %>
    </div>
  </div>

  <div class="nav__group" data-controller="menu"
      data-action="keydown.esc->menu#closeAndFocus keydown.down->menu#moveDown keydown.up->menu#moveUp focusout->menu#closeOnFocusOut">
    <%= button_tag type: "button", class: "nav__link nav__trigger",
          data: { menu_target: "button", action: "menu#toggle" },
          aria: { expanded: "false", current: nav_section_current?(domains_path, sources_path, templates_path, webhook_endpoints_path, api_keys_path) ? "true" : nil } do %>
      Configure<%= icon_tag "caret-down", class: "nav__caret" %>
    <% end %>
    <div class="menu" data-menu-target="panel" hidden>
      <%= menu_link_to "Domains", domains_path %>
      <%= menu_link_to "Sources", sources_path %>
      <%= menu_link_to "Templates", templates_path %>
      <%= menu_link_to "Webhooks", webhook_endpoints_path %>
      <%= menu_link_to "API keys", api_keys_path %>
    </div>
  </div>
</nav>
