<div class="nav__group" data-controller="menu"
    data-action="keydown.esc->menu#closeAndFocus keydown.down->menu#moveDown keydown.up->menu#moveUp focusout->menu#closeOnFocusOut">
  <button type="button" class="btn btn--plain" data-menu-target="button"
      data-action="menu#toggle" aria-expanded="false">
    <%= Current.workspace&.name || "Workspace" %><%= icon_tag "caret-down", class: "nav__caret" %>
  </button>
  <div class="menu menu--end" data-menu-target="panel" hidden>
    <% if Current.user.workspaces.many? %>
      <p class="menu__heading" id="workspace_switch_heading">Switch workspace</p>
      <% Current.user.workspaces.each do |workspace| %>
        <%= button_to workspace.name, workspace_switch_path(workspace), class: "menu__item",
              aria: { current: workspace == Current.workspace ? "true" : nil } %>
      <% end %>
      <hr class="menu__rule">
    <% end %>
    <% if Current.workspace&.capability?(Current.user, :manage_members) %>
      <%= menu_link_to "Workspace settings", edit_workspace_path(Current.workspace) %>
    <% end %>
    <% if Current.workspace&.capability?(Current.user, :view_audit_log) %>
      <%= menu_link_to "Audit log", audit_events_path %>
    <% end %>
    <%= menu_link_to "New workspace", new_workspace_path %>
  </div>
</div>
