<h1>Create a workspace</h1>

<% if @workspace.errors.any? %>
  <ul class="txt-negative">
    <% @workspace.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<%= form_with model: @workspace, url: workspaces_path, class: "flex flex-column gap" do |form| %>
  <div class="flex flex-column gap-half">
    <%= form.label :name %>
    <%= form.text_field :name, class: "input", required: true, autofocus: true %>
  </div>
  <%= form.submit "Create workspace", class: "btn btn--primary btn--medium" %>
<% end %>
